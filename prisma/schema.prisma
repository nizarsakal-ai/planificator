  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("gmail_connections")
}

// ═══════════════════════════════════════════════════════════════════════════
// PROCESSED GMAIL MESSAGE — Évite le retraitement des emails déjà analysés
// ═══════════════════════════════════════════════════════════════════════════

model ProcessedGmailMessage {
