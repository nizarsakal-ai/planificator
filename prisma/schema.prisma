  updatedAt    DateTime  @updatedAt

  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  worksite  Worksite? @relation(fields: [worksiteId], references: [id], onDelete: SetNull)

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([companyId])
  @@index([date])
  @@map("timeclocks")
}

// ═══════════════════════════════════════════════════════════════════════════
// DAILY REPORT — Rapport journalier rempli par le chef d'équipe
// ═══════════════════════════════════════════════════════════════════════════

model DailyReport {
  id          String           @id @default(cuid())
  worksiteId  String
  teamId      String
  createdById String
  date        DateTime         @db.Date
  weather     WeatherCondition @default(SUNNY)
  description String
  issues      String?
  hoursWorked Float            @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  worksite  Worksite @relation(fields: [worksiteId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id])
  createdBy Employee @relation(fields: [createdById], references: [id])

  @@unique([teamId, date])
  @@index([worksiteId])
  @@index([teamId])
  @@index([date])
  @@index([createdById])
  @@map("daily_reports")
}

// ═══════════════════════════════════════════════════════════════════════════
// SIGNATURE — Signature électronique de la feuille de présence
// Liée à une affectation (1-to-1), signée par le chef d'équipe
// ═══════════════════════════════════════════════════════════════════════════

model Signature {
  id           String   @id @default(cuid())
  assignmentId String   @unique
  signedById   String   // employeeId of the team leader who signed
  signatureUrl String   // Cloudinary URL of the signature image
  signedAt     DateTime @default(now())

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  signedBy   Employee   @relation(fields: [signedById], references: [id])

  @@index([assignmentId])
  @@index([signedById])
  @@map("signatures")
}

// ═══════════════════════════════════════════════════════════════════════════
// ACCOMMODATION — Logement réservé pour une équipe
// ═══════════════════════════════════════════════════════════════════════════

model Accommodation {
  id           String              @id @default(cuid())
  companyId    String
  teamId       String
  createdById  String              // userId de l'admin qui a créé

  status       AccommodationStatus @default(UPCOMING)

  startDate    DateTime            @db.Date
  endDate      DateTime            @db.Date

  address      String
  city         String?
  zipCode      String?

  doorCode     String?
  contactName  String?
  contactPhone String?

  notes        String?

  // Source & référence externe
  bookingReference  String?  @unique  // Numéro de réservation Booking.com
  source            String?  @default("manual")  // "manual" | "gmail-scan" | "n8n"

