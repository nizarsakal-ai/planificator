model Truck {
  id          String   @id @default(cuid())
  matricule   String
  marque      String?
  companyId   String
  teamId      String?  @unique
  chauffeurId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team        Team?             @relation(fields: [teamId], references: [id], onDelete: SetNull)
  chauffeur   Employee?         @relation("TruckChauffeur", fields: [chauffeurId], references: [id], onDelete: SetNull)
  assignments TruckAssignment[]

  @@unique([matricule, companyId])
  @@index([companyId])
  @@index([chauffeurId])
  @@map("trucks")
}

// ═══════════════════════════════════════════════════════════════════════════
// ASSISTANT CONSULTATIONS — Fondation acquisition d'emails (inactif par défaut)
// Email entrant → AcquisitionMessage (idempotent) → WorksiteImportDraft.
// Aucun connecteur Gmail, aucun appel IA, aucune création de chantier dans
// cette phase. Activation future via PLANIFICATOR_ACQUISITION_ENABLED.
// ═══════════════════════════════════════════════════════════════════════════

model AcquisitionMessage {
  id                 String                   @id @default(cuid())
  companyId          String
  source             AcquisitionSource
  externalMessageId  String
  senderEmail        String
  senderDomain       String
  subject            String
  receivedAt         DateTime
  status             AcquisitionMessageStatus @default(RECEIVED)
  processingAttempts Int                      @default(0)
  lastErrorCode      String?
  lastErrorMessage   String?
  rawMetadata        Json?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  company     Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  draft       WorksiteImportDraft?
  attachments AcquisitionAttachment[]
  content     AcquisitionMessageContent?

  // Idempotence par tenant : le même id Gmail peut exister chez deux
  // entreprises, jamais deux fois pour la même entreprise et la même source.
  @@unique([companyId, source, externalMessageId])
  // Cible des FK composites (draft, attachments) : garantit EN BASE que
  // l'enfant porte le même companyId que son message (anti inter-tenant).
  @@unique([id, companyId])
  @@index([companyId, status])
  @@index([companyId, receivedAt])
  @@map("acquisition_messages")
}

// PLAN-ACQ-005A — Contenu email normalisé (jamais MIME/body.data/HTML brut).
model AcquisitionMessageContent {
  id                   String   @id @default(cuid())
  companyId            String
  acquisitionMessageId String   @unique
  normalizedText       String   @db.Text
  contentHash          String
  sourceMimeType       String?
  sourceCharset        String?
  hadHtml              Boolean  @default(false)
  byteLengthOriginal   Int      @default(0)
  fetchedAt            DateTime
  sanitizedAt          DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  company            Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // FK composite anti inter-tenant (même pattern que draft / attachments).
  acquisitionMessage AcquisitionMessage @relation(fields: [acquisitionMessageId, companyId], references: [id, companyId], onDelete: Cascade)

  @@unique([acquisitionMessageId, companyId])
  @@index([companyId])
  @@map("acquisition_message_contents")
}

model WorksiteImportDraft {
  id                   String                    @id @default(cuid())
  companyId            String
  acquisitionMessageId String                    @unique
  status               WorksiteImportDraftStatus @default(PENDING_EXTRACTION)
  proposedClientId     String?
  proposedClientName   String?
  proposedWorksiteName String?
  proposedAddress      String?
  proposedPostalCode   String?
  proposedCity         String?
  proposedContactName  String?
  proposedContactEmail String?
  proposedContactPhone String?
  proposedStartDate    DateTime?
  proposedEndDate      DateTime?
  proposedDescription  String?
  extractedData        Json?
  confidenceData       Json?
  // PLAN-ACQ-005B — warnings catalogués (pas de texte provider libre)
  warningData          Json?
  version              Int                       @default(0)
  extractionStartedAt  DateTime?
  extractionCompletedAt DateTime?
  contentHashAtExtraction String?
  extractionSchemaVersion String?
  extractionAttemptCount  Int                    @default(0)
  extractionProvider   String?
  extractionModel      String?
  lastExtractionErrorCode String?
  lastExtractionErrorAt   DateTime?
  reviewedByUserId     String?
  reviewedAt           DateTime?
  rejectionReason      String?
  createdWorksiteId    String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  company            Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // FK composite (acquisitionMessageId, companyId) → (id, companyId) :
  // la base REFUSE un brouillon dont le companyId diffère de celui du message.
  acquisitionMessage AcquisitionMessage @relation(fields: [acquisitionMessageId, companyId], references: [id, companyId], onDelete: Cascade)
  proposedClient     Client?            @relation(fields: [proposedClientId], references: [id], onDelete: SetNull)
  reviewedBy         User?              @relation("ImportDraftReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  createdWorksite    Worksite?          @relation(fields: [createdWorksiteId], references: [id], onDelete: SetNull)

  // Requis par Prisma pour la relation 1-1 composite ; l'unicité simple sur
  // acquisitionMessageId (plus forte) reste la garantie métier du 1-1.
  @@unique([acquisitionMessageId, companyId])
  @@index([companyId, status])
  @@map("worksite_import_drafts")
}

model AcquisitionAttachment {
  id                   String                        @id @default(cuid())
  companyId            String
  acquisitionMessageId String
  // Identité STABLE de la pièce jointe dans son message, calculée par le
  // service : "ext:<externalAttachmentId>" si fourni, sinon "part:<partId>"
  // (partie MIME), sinon "ord:<position>" (ordinal stable). Jamais le seul
  // filename. Garantit l'idempotence même sans identifiant Gmail exploitable.
  attachmentKey        String
  externalAttachmentId String?
  filename             String
  mimeType             String
  sizeBytes            Int
  category             AcquisitionAttachmentCategory @default(UNKNOWN)
  status               AcquisitionAttachmentStatus   @default(DISCOVERED)
  storageUrl           String?
  storagePublicId      String?
  sha256               String?
  storedAt             DateTime?
  lastErrorCode        String?
  lastErrorAt          DateTime?
  // PLAN-ACQ-004D — reclaim / retry (pas d'historique attempts séparé en V1)
  downloadClaimedAt    DateTime?
  downloadRetryCount   Int                           @default(0)
  downloadNextRetryAt  DateTime?
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt

  company            Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // FK composite : même garantie anti inter-tenant que pour les brouillons.
  acquisitionMessage AcquisitionMessage @relation(fields: [acquisitionMessageId, companyId], references: [id, companyId], onDelete: Cascade)
  accessLogs         AcquisitionAttachmentAccessLog[]

  @@unique([id, companyId])
  @@unique([acquisitionMessageId, attachmentKey])
  @@index([companyId])
  @@index([acquisitionMessageId])
  @@index([companyId, status, createdAt])
  @@index([status, downloadClaimedAt])
  @@index([companyId, status, downloadNextRetryAt])
  @@map("acquisition_attachments")
}

model AcquisitionAttachmentAccessLog {
  id                    String                             @id @default(cuid())
  companyId             String
  attachmentId          String?
  requestedAttachmentId String
  userId                String
  action                AcquisitionAttachmentAccessAction
  outcome               AcquisitionAttachmentAccessOutcome
  reasonCode            String?
  createdAt             DateTime                           @default(now())

  company    Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachment AcquisitionAttachment? @relation(fields: [attachmentId, companyId], references: [id, companyId], onDelete: Restrict, onUpdate: Cascade)

  @@index([companyId, createdAt])
  @@index([companyId, requestedAttachmentId, createdAt])
  @@index([userId, createdAt])
  @@map("acquisition_attachment_access_logs")
}

// Curseur de synchronisation mail par tenant et source (Gmail, futur Outlook/IMAP).
// Aucun token OAuth — uniquement watermark de reprise.
model AcquisitionScanCursor {
  id                  String            @id @default(cuid())
  companyId           String
  source              AcquisitionSource
  lastHistoryId       String?
  lastSyncedAt        DateTime?
  consecutiveFailures Int               @default(0)
  lastErrorCode       String?
  lastErrorAt         DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, source])
  @@map("acquisition_scan_cursors")
}

// Historique des affectations camion : qui conduisait quel camion, dans
// quelle équipe, sur quelle période. Une ligne ouverte (endedAt null) =
// affectation en cours. Permet de retrouver le chauffeur d'un camion à
// une date donnée (amendes, infractions, accidents).
model TruckAssignment {
  id          String    @id @default(cuid())
  truckId     String
  chauffeurId String?
  teamId      String?
  companyId   String
  startedAt   DateTime  @default(now())
  endedAt     DateTime?

  truck     Truck     @relation(fields: [truckId], references: [id], onDelete: Cascade)
  chauffeur Employee? @relation("TruckAssignmentChauffeur", fields: [chauffeurId], references: [id], onDelete: SetNull)
  team      Team?     @relation("TruckAssignmentTeam", fields: [teamId], references: [id], onDelete: SetNull)

  @@index([truckId, startedAt])
  @@index([chauffeurId])
  @@index([companyId])
  @@map("truck_assignments")
}
