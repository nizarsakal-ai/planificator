// ═══════════════════════════════════════════════════════════════════════════
// PENDING ACCOMMODATION — Réservation détectée, en attente d'attribution équipe
// ═══════════════════════════════════════════════════════════════════════════

model PendingAccommodation {
  id              String                     @id @default(cuid())
  companyId       String
  gmailMessageId  String

  propertyName    String?
  address         String?
  city            String?
  zipCode         String?
  startDate       DateTime?                  @db.Date
  endDate         DateTime?                  @db.Date
  doorCode        String?
  contactName     String?
  contactPhone    String?
  notes           String?
  rawEmailSnippet String?

  status          PendingAccommodationStatus @default(PENDING)
  accommodationId String?
  confirmedById   String?
  confirmedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
